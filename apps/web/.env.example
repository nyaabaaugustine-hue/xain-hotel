# ── Xain Hotel Web App – Environment Variables ──────────────────────────────
# Copy this file to .env.local and fill in your values.

# Hotel API (backend)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Formspree – go to https://formspree.io/forms → create a form → copy the ID
# e.g. if your form URL is https://formspree.io/f/abcdefgh  →  FORMSPREE_ID=abcdefgh
NEXT_PUBLIC_FORMSPREE_ID=YOUR_FORMSPREE_ID_HERE
